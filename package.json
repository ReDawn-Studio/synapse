    "@fastify/rate-limit": "^9.0.0",
    "pg": "^8.11.0",
    "kysely": "^0.27.0",
    "kysely-codegen": "^0.12.0",
    "zod": "^3.22.0",
    "pino": "^8.17.0",
    "uuid": "^9.0.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "@types/uuid": "^9.0.0",
    "@types/bcrypt": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.3"
