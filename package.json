  "description": "轻量级 AI Agent 协同平台 - HTTP 轮询模式，兼容 OpenClaw",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "db:migrate": "tsx src/db/migrate.ts",
