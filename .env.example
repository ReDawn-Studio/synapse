# Synapse Backend Environment Configuration
# Copy this file to .env and fill in your values

# Node.js Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Connection
DATABASE_URL=postgres://synapse:synapse_dev_password@localhost:5432/synapse

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Logging
LOG_LEVEL=info

# Rate Limiting (requests per minute)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

# CORS (comma-separated origins or 'true' for all)
CORS_ORIGIN=true
